{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bananascanner-website",
  "compatibility_date": "2026-05-24",
  "assets": {
    "directory": "./dist",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "bananascanner.com", "custom_domain": true },
    { "pattern": "www.bananascanner.com", "custom_domain": true }
  ]
}
