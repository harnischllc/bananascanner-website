---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = 'Go Bananas',
  description = 'Go Bananas: Banana Scanner. iOS and Android app that scans bananas with the camera and tells you when each one is at its peak. Published by Harnisch LLC.',
  path = Astro.url.pathname,
} = Astro.props;

const fullTitle =
  title === 'Go Bananas' ? `${title} · Banana Scanner` : `${title} · Go Bananas`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={new URL(path, Astro.site).toString()} />
    <meta name="theme-color" content="#f5c518" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(path, Astro.site).toString()} />
    <meta property="og:image" content={new URL('/banana-mark.svg', Astro.site).toString()} />
    <meta name="twitter:card" content="summary" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'MobileApplication',
        name: 'Go Bananas: Banana Scanner',
        operatingSystem: 'iOS, Android',
        applicationCategory: 'UtilityApplication',
        description,
        url: 'https://bananascanner.com',
        author: {
          '@type': 'Organization',
          name: 'Harnisch LLC',
          url: 'https://harnischllc.com',
        },
      })}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container-quiet footer-inner">
        <p class="footer-line">
          Go Bananas is published by{' '}
          <a href="https://harnischllc.com">Harnisch LLC</a>. &copy; {year}.
        </p>
        <nav class="footer-nav" aria-label="Footer">
          <a href="/">Home</a>
          <span aria-hidden="true">·</span>
          <a href="/privacy">Privacy</a>
          <span aria-hidden="true">·</span>
          <a href="/support">Support</a>
        </nav>
      </div>
    </footer>

    <div class="peek-monkey" aria-hidden="true">🐒</div>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }
      .skip-link:focus {
        position: fixed;
        left: 1rem;
        top: 1rem;
        width: auto;
        height: auto;
        padding: 0.5rem 0.875rem;
        background: var(--ink);
        color: var(--banana-yellow);
        z-index: 50;
        border: 0;
      }

      .site-footer {
        margin-top: auto;
        border-top: 2px solid var(--ink);
        padding-block: clamp(1.5rem, 3vw, 2rem);
        background: var(--bg);
      }

      .footer-inner {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-start;
      }

      .footer-line {
        font-family: var(--font-sans);
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        color: var(--text);
        margin: 0;
      }

      .footer-nav {
        display: flex;
        gap: 0.6rem;
        align-items: center;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .footer-nav a {
        border-bottom-width: 1px;
      }

      @media (min-width: 640px) {
        .footer-inner {
          flex-direction: row;
          justify-content: space-between;
          align-items: center;
        }
      }

      /* Hidden monkey, peeks in when you scroll to the bottom */
      .peek-monkey {
        position: fixed;
        right: -40px;
        bottom: 80px;
        font-size: 32px;
        z-index: 20;
        opacity: 0;
        transform: translateX(40px) rotate(15deg);
        transition:
          opacity 400ms ease,
          transform 500ms cubic-bezier(0.3, 1.4, 0.5, 1);
        pointer-events: none;
        user-select: none;
        line-height: 1;
      }
      .peek-monkey.peeking {
        opacity: 1;
        transform: translateX(-12px) rotate(-6deg);
      }

      /* Falling monkeys + bananas on Konami / monkeys() */
      .falling-mate {
        position: fixed;
        top: -8vh;
        z-index: 9999;
        pointer-events: none;
        user-select: none;
        animation-name: gb-fall;
        animation-timing-function: linear;
        animation-fill-mode: forwards;
        line-height: 1;
      }
      @keyframes gb-fall {
        0% {
          transform: translateY(-10vh) rotate(0deg);
          opacity: 1;
        }
        90% {
          opacity: 1;
        }
        100% {
          transform: translateY(115vh) rotate(720deg);
          opacity: 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .peek-monkey,
        .falling-mate {
          display: none !important;
        }
      }
    </style>

    <script is:inline>
      // Hello, devs. Open this on a banana page and find this.
      console.log(
        '%c\n' +
          '   .-""""""""""-.\n' +
          '  /              \\\n' +
          ' |   🍌  GO        |\n' +
          ' |       BANANAS   |\n' +
          '  \\              /\n' +
          "   '-..........-'\n\n" +
          "  hello, fellow inspector. type monkeys() for chaos.\n",
        'background:#f5c518;color:#1f1d18;font-family:ui-monospace,Menlo,monospace;font-weight:700;padding:8px 10px;border-radius:6px;line-height:1.4;'
      );

      // monkeys() — call from the console. Or the Konami code.
      (function () {
        var GLYPHS = ['🐒', '🍌', '🍌', '🙊', '🙉', '🙈', '🍌', '🐒', '🍌'];

        function rain() {
          if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          for (var i = 0; i < 60; i++) {
            var el = document.createElement('span');
            el.className = 'falling-mate';
            el.textContent = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
            el.style.left = Math.random() * 100 + 'vw';
            el.style.animationDuration = 2 + Math.random() * 3 + 's';
            el.style.animationDelay = Math.random() * 1.5 + 's';
            el.style.fontSize = 24 + Math.random() * 36 + 'px';
            document.body.appendChild(el);
            el.addEventListener('animationend', function () {
              this.remove();
            });
          }
        }

        window.monkeys = function () {
          rain();
          return 'the monkeys got loose. ' + '🐒'.repeat(8);
        };

        document.addEventListener('gobananas:monkeys', rain);

        // Konami code: ↑ ↑ ↓ ↓ ← → ← → B A
        var KONAMI = [
          'ArrowUp',
          'ArrowUp',
          'ArrowDown',
          'ArrowDown',
          'ArrowLeft',
          'ArrowRight',
          'ArrowLeft',
          'ArrowRight',
          'b',
          'a',
        ];
        var kIdx = 0;
        window.addEventListener('keydown', function (e) {
          var k = e.key.length === 1 ? e.key.toLowerCase() : e.key;
          if (k === KONAMI[kIdx]) {
            kIdx++;
            if (kIdx === KONAMI.length) {
              kIdx = 0;
              rain();
            }
          } else {
            kIdx = k === KONAMI[0] ? 1 : 0;
          }
        });

        // Peek monkey on scroll-to-bottom
        var monkey = document.querySelector('.peek-monkey');
        var peekActive = false;
        function onScroll() {
          if (!monkey) return;
          if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          var nearBottom =
            window.innerHeight + window.scrollY >=
            document.documentElement.scrollHeight - 220;
          if (nearBottom && !peekActive) {
            peekActive = true;
            monkey.classList.add('peeking');
          } else if (!nearBottom && peekActive) {
            peekActive = false;
            monkey.classList.remove('peeking');
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        // Check once on load in case the page is already short.
        document.addEventListener('DOMContentLoaded', onScroll);
      })();
    </script>
  </body>
</html>
