---
import Base from '../layouts/Base.astro';
---

<Base
  title="Go Bananas"
  description="Catch every banana at its peak. Scans bananas with your camera and rates ripeness on-device. Out now on Google Play; iOS beta on TestFlight. Published by Harnisch LLC."
  path="/"
>
  <section class="hero container-quiet">
    <div class="hero-grid">
      <button
        class="hero-mark"
        type="button"
        aria-label="Squish the banana"
        data-banana
      >
        <img src="/banana-mark.svg" alt="" width="320" height="320" />
      </button>
      <div class="hero-copy">
        <h1 class="hero-title">
          GO<br />BANANAS
        </h1>
        <p class="hero-tag">
          Catch every banana at its{' '}
          <span class="peak-word" tabindex="0">peak</span>.
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var banana = document.querySelector('[data-banana]');
      if (!banana) return;
      var reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reducedMotion) return; // No counter, no clicks, no JS — let the CSS reduce-motion rules carry it.

      // Three brand-palette colors plus the deep yellow; tokens are mirrored
      // so the burst stays in sync if the palette ever shifts.
      var BIT_COLORS = ['#f5c518', '#d9a800', '#5d9a3f', '#8a5a2b'];

      var streak = 0;
      var resetTimer;

      banana.addEventListener('click', function () {
        streak++;
        // Wait for the actual animation end, not a wall-clock timeout, so
        // a busy thread can't yank the class mid-frame.
        banana.classList.add('squish');
        banana.addEventListener('animationend', clearSquish, { once: true });

        clearTimeout(resetTimer);
        resetTimer = setTimeout(function () { streak = 0; }, 1500);

        // Every click bursts. Streak escalates: 1 → 8 bits, 2 → 16, 3+ → 36.
        var bits = streak === 1 ? 8 : streak === 2 ? 16 : 36;
        bananaBurst(bits);
      });

      function clearSquish() {
        banana.classList.remove('squish');
      }

      function bananaBurst(count) {
        // Use offset geometry (un-transformed) so the origin doesn't drift
        // with the wobble's rotate/scale.
        var cx = banana.offsetLeft + banana.offsetWidth / 2;
        var cy = banana.offsetTop + banana.offsetHeight / 2;
        // Translate to viewport coords for position:fixed bits.
        cx -= window.scrollX;
        cy -= window.scrollY;

        // Per-bit floor so bits fall to roughly the bottom of the viewport
        // instead of every bit getting the same 70vh push.
        var floor = window.innerHeight - cy + 60;

        for (var i = 0; i < count; i++) {
          var el = document.createElement('span');
          el.className = 'banana-bit';
          el.textContent = '🍌';
          el.style.left = cx + 'px';
          el.style.top = cy + 'px';

          // Jittered angle so the burst doesn't read as a clock-face.
          var angle = (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 0.6;
          var dist = 160 + Math.random() * 220;
          el.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
          el.style.setProperty('--ty', Math.sin(angle) * dist - 40 + 'px');
          el.style.setProperty('--fall', floor + 'px');
          el.style.animationDuration = 0.9 + Math.random() * 0.7 + 's';
          el.style.animationDelay = Math.random() * 0.12 + 's';
          el.style.fontSize = 22 + Math.random() * 28 + 'px';
          // Color-tint roughly 35% of the bits with an accent so the burst
          // reads as a ripening arc, not a flat yellow puff.
          if (Math.random() < 0.35) {
            el.style.color = BIT_COLORS[Math.floor(Math.random() * BIT_COLORS.length)];
          }
          document.body.appendChild(el);
          el.addEventListener('animationend', function () { this.remove(); }, { once: true });
        }
      }
    })();
  </script>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="lead">
      Point your phone's camera at a banana. The app reads the color of the
      peel and tells you what stage it's in, from green to overripe, so you
      eat each one when it's actually good.
    </p>
    <p class="lead">
      Everything happens on your device. Photos never leave your phone. No
      account, no tracking.
    </p>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">Inside the app</p>
    <div class="screens screens-centered">
      <figure class="phone">
        <div class="phone-frame">
          <img
            src="/screens/home-scan.png"
            alt="Go Bananas home screen with the Scan with camera button"
            width="600"
            height="1304"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="phone-cap">Scan with your camera</figcaption>
      </figure>
      <figure class="phone">
        <div class="phone-frame">
          <img
            src="/screens/banana-bunch.png"
            alt="The Banana Bunch screen tracking named bananas and their ripeness"
            width="600"
            height="1304"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="phone-cap">Track your bunch</figcaption>
      </figure>
      <figure class="phone">
        <div class="phone-frame">
          <img
            src="/screens/rewards.png"
            alt="Rewards screen with the daily crate, streaks, and variety collection"
            width="600"
            height="1304"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="phone-cap">Daily crates and streaks</figcaption>
      </figure>
    </div>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">Get the app</p>
    <p class="status-line">
      Out now on Android. On iOS it's in TestFlight beta, with the App Store
      release coming; <a href="/support">get in touch</a> for early access.
    </p>
    <a
      class="store-badge"
      href="https://play.google.com/store/apps/details?id=com.harnischllc.gobananas"
    >
      <img
        src="/google-play-badge.png"
        alt="Get it on Google Play"
        width="646"
        height="250"
        loading="lazy"
        decoding="async"
      />
    </a>
    <p class="badge-legal">
      Google Play and the Google Play logo are trademarks of Google LLC.
    </p>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">More</p>
    <ul class="link-list" role="list">
      <li><a href="/facts">Banana facts</a></li>
      <li><a href="/privacy">Privacy policy</a></li>
      <li><a href="/support">Support and contact</a></li>
      <li><a href="https://harnischllc.com">Harnisch LLC</a></li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    justify-items: center;
  }

  .hero-mark {
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    width: clamp(180px, 32vw, 300px);
    aspect-ratio: 1;
    transition: transform 200ms ease;
    border-radius: 999px;
  }

  .hero-mark img {
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }

  /* Wobble only on devices with a real hover (no sticky hover after tap on iOS). */
  @media (hover: hover) and (pointer: fine) {
    .hero-mark:hover {
      animation: gb-wobble 1.2s ease-in-out infinite;
    }
    /* While squishing on a hovering device, freeze the wobble so the post-squish
       resume doesn't snap to a different rotation. */
    .hero-mark.squish:hover {
      animation: gb-squish 280ms ease;
    }
  }

  .hero-mark.squish {
    animation: gb-squish 280ms ease;
  }

  .hero-mark:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 6px;
  }

  @keyframes gb-wobble {
    0%, 100% { transform: rotate(-3deg) scale(1); }
    50% { transform: rotate(3deg) scale(1.02); }
  }

  @keyframes gb-squish {
    0% { transform: scale(1) rotate(0); }
    40% { transform: scale(0.88) rotate(-6deg); }
    70% { transform: scale(1.04) rotate(3deg); }
    100% { transform: scale(1) rotate(0); }
  }

  .peak-word {
    display: inline-block;
    cursor: help;
    transition: transform 200ms ease;
    font-weight: 800;
    border-bottom: 2px dashed var(--ink);
    line-height: 1;
  }

  .peak-word:hover,
  .peak-word:focus,
  .peak-word:focus-visible {
    animation: gb-ripen 1.4s steps(1) infinite;
    transform: scale(1.06);
    outline: none;
  }

  /* Four-stage ripen using brand tokens. Drop the in-between lime — keeping
     animation honest to the actual palette beats fudging a hex. */
  @keyframes gb-ripen {
    0%, 24%   { color: var(--accent-green); }
    25%, 49%  { color: var(--banana-yellow); }
    50%, 74%  { color: var(--banana-yellow-deep); }
    75%, 100% { color: var(--accent-brown); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-mark:hover,
    .hero-mark.squish,
    .peak-word:hover,
    .peak-word:focus,
    .peak-word:focus-visible {
      animation: none;
      transform: none;
    }
    /* JS exits early when reduced-motion is on so no .banana-bit nodes are
       created; no display:none rule needed. */
  }

  .hero-copy {
    text-align: center;
  }

  .hero-title {
    font-size: var(--text-display);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.045em;
    margin: 0;
    color: var(--ink);
  }

  .hero-tag {
    margin-top: 1.1rem;
    font-size: var(--text-lead);
    font-weight: 700;
    color: var(--ink);
    text-wrap: balance;
    margin-inline: auto;
  }

  .section {
    padding-block: clamp(2.25rem, 5vw, 3.5rem);
  }

  .status-line {
    margin-top: 0.4rem;
    font-size: 1.0625rem;
    color: var(--text);
    max-width: var(--max-prose);
    font-weight: 500;
  }

  /* The official badge artwork carries its own padding, so pull it back
     toward the text's left edge instead of double-indenting. */
  .store-badge {
    display: inline-block;
    margin: 0.9rem 0 0 -10px;
    text-decoration: none;
    border-bottom: 0;
  }

  .store-badge img {
    display: block;
    height: 72px;
    width: auto;
  }

  .badge-legal {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .link-list {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 600;
  }

  @media (min-width: 720px) {
    .hero-grid {
      grid-template-columns: minmax(220px, 1fr) 2fr;
      justify-items: start;
    }

    .hero-mark {
      justify-self: start;
    }

    .hero-copy {
      text-align: left;
    }

    .hero-tag {
      margin-inline: 0;
    }
  }
</style>
