---
import Base from '../layouts/Base.astro';
---

<Base
  title="Go Bananas"
  description="Catch every banana at its peak. iOS and Android app that scans bananas with your camera and rates ripeness on-device. Published by Harnisch LLC."
  path="/"
>
  <section class="hero container-quiet">
    <div class="hero-grid">
      <button
        class="hero-mark"
        type="button"
        aria-label="Squish the banana"
        data-banana
      >
        <img src="/banana-mark.svg" alt="" width="320" height="320" />
      </button>
      <div class="hero-copy">
        <h1 class="hero-title">
          GO<br />BANANAS
        </h1>
        <p class="hero-tag">
          Catch every banana at its{' '}
          <span class="peak-word" tabindex="0">peak</span>.
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var banana = document.querySelector('[data-banana]');
      if (!banana) return;
      var clicks = 0;
      var resetTimer;
      banana.addEventListener('click', function () {
        clicks++;
        banana.classList.add('squish');
        setTimeout(function () {
          banana.classList.remove('squish');
        }, 280);
        clearTimeout(resetTimer);
        resetTimer = setTimeout(function () {
          clicks = 0;
        }, 1500);
        if (clicks >= 5) {
          clicks = 0;
          bananaBurst();
        }
      });

      function bananaBurst() {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var rect = banana.getBoundingClientRect();
        var cx = rect.left + rect.width / 2;
        var cy = rect.top + rect.height / 2;
        for (var i = 0; i < 36; i++) {
          var el = document.createElement('span');
          el.className = 'banana-bit';
          el.textContent = '🍌';
          el.style.left = cx + 'px';
          el.style.top = cy + 'px';
          var angle = (i / 36) * Math.PI * 2;
          var dist = 180 + Math.random() * 220;
          el.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
          el.style.setProperty(
            '--ty',
            Math.sin(angle) * dist - 40 + 'px'
          );
          el.style.animationDuration = 0.9 + Math.random() * 0.7 + 's';
          el.style.fontSize = 22 + Math.random() * 28 + 'px';
          document.body.appendChild(el);
          el.addEventListener('animationend', function () {
            this.remove();
          });
        }
      }
    })();
  </script>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="lead">
      Point your phone's camera at a banana. The app reads the color of the
      peel and tells you what stage it's in, from green to overripe, so you
      eat each one when it's actually good.
    </p>
    <p class="lead">
      Everything happens on your device. No upload, no account, no tracking.
    </p>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">Status</p>
    <p class="status-line">
      In TestFlight beta on iOS. In Google Play internal testing on Android.
      Public release coming. <a href="/support">Get in touch</a> for early
      access.
    </p>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">More</p>
    <ul class="link-list" role="list">
      <li><a href="/privacy">Privacy policy</a></li>
      <li><a href="/support">Support and contact</a></li>
      <li><a href="https://harnischllc.com">Harnisch LLC</a></li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    justify-items: center;
  }

  .hero-mark {
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    width: clamp(180px, 32vw, 300px);
    aspect-ratio: 1;
    transition: transform 200ms ease;
    border-radius: 999px;
  }

  .hero-mark img {
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }

  .hero-mark:hover {
    animation: gb-wobble 1.2s ease-in-out infinite;
  }

  .hero-mark.squish {
    animation: gb-squish 280ms ease;
  }

  .hero-mark:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 6px;
  }

  @keyframes gb-wobble {
    0%, 100% { transform: rotate(-3deg) scale(1); }
    50% { transform: rotate(3deg) scale(1.02); }
  }

  @keyframes gb-squish {
    0% { transform: scale(1) rotate(0); }
    40% { transform: scale(0.88) rotate(-6deg); }
    70% { transform: scale(1.04) rotate(3deg); }
    100% { transform: scale(1) rotate(0); }
  }

  .peak-word {
    display: inline-block;
    cursor: help;
    transition: transform 200ms ease;
    font-weight: 800;
    border-bottom: 2px dashed var(--ink);
    line-height: 1;
  }

  .peak-word:hover,
  .peak-word:focus-visible {
    animation: gb-ripen 1.4s steps(1) infinite;
    transform: scale(1.06);
    outline: none;
  }

  @keyframes gb-ripen {
    0%, 16% { color: #5d9a3f; }
    17%, 40% { color: #c4d44a; }
    41%, 63% { color: #f5c518; }
    64%, 83% { color: #d9a800; }
    84%, 100% { color: #8a5a2b; }
  }

  /* Banana confetti burst */
  .banana-bit {
    position: fixed;
    z-index: 9999;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    animation-name: gb-burst;
    animation-timing-function: cubic-bezier(0.2, 0.5, 0.5, 1);
    animation-fill-mode: forwards;
  }

  @keyframes gb-burst {
    0% {
      transform: translate(0, 0) rotate(0);
      opacity: 1;
    }
    100% {
      transform: translate(var(--tx), calc(var(--ty) + 70vh)) rotate(720deg);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-mark:hover,
    .hero-mark.squish,
    .peak-word:hover,
    .peak-word:focus-visible {
      animation: none;
      transform: none;
    }
    .banana-bit { display: none; }
  }

  .hero-copy {
    text-align: center;
  }

  .hero-title {
    font-size: var(--text-display);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.045em;
    margin: 0;
    color: var(--ink);
  }

  .hero-tag {
    margin-top: 1.1rem;
    font-size: clamp(1.0625rem, 1.4vw + 0.65rem, 1.4rem);
    font-weight: 700;
    color: var(--ink);
    max-width: 22ch;
    text-wrap: balance;
    margin-inline: auto;
  }

  .section {
    padding-block: clamp(2.25rem, 5vw, 3.5rem);
  }

  .status-line {
    margin-top: 0.4rem;
    font-size: 1.0625rem;
    color: var(--text);
    max-width: var(--max-prose);
    font-weight: 500;
  }

  .link-list {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 600;
  }

  @media (min-width: 720px) {
    .hero-grid {
      grid-template-columns: minmax(220px, 1fr) 2fr;
      justify-items: start;
    }

    .hero-mark {
      justify-self: start;
    }

    .hero-copy {
      text-align: left;
    }

    .hero-tag {
      margin-inline: 0;
    }
  }
</style>
