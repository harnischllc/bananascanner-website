---
import Base from '../layouts/Base.astro';
---

<Base
  title="Go Bananas"
  description="Catch every banana at its peak. iOS and Android app that scans bananas with your camera and rates ripeness on-device. Published by Harnisch LLC."
  path="/"
>
  <section class="hero container-quiet">
    <div class="hero-grid">
      <div class="hero-mark" aria-hidden="true">
        <img src="/banana-mark.svg" alt="" width="320" height="320" />
      </div>
      <div class="hero-copy">
        <h1 class="hero-title">
          GO<br />BANANAS
        </h1>
        <p class="hero-tag">Catch every banana at its peak.</p>
      </div>
    </div>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="lead">
      Point your phone's camera at a banana. The app reads the color of the
      peel and tells you what stage it's in, from green to overripe, so you
      eat each one when it's actually good.
    </p>
    <p class="lead">
      Everything happens on your device. No upload, no account, no tracking.
    </p>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">Status</p>
    <p class="status-line">
      In TestFlight beta on iOS. In Google Play internal testing on Android.
      Public release coming. <a href="/support">Get in touch</a> for early
      access.
    </p>
  </section>

  <hr class="section-rule" />

  <section class="container-quiet section">
    <p class="eyebrow">More</p>
    <ul class="link-list" role="list">
      <li><a href="/privacy">Privacy policy</a></li>
      <li><a href="/support">Support and contact</a></li>
      <li><a href="https://harnischllc.com">Harnisch LLC</a></li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    justify-items: center;
  }

  .hero-mark {
    width: clamp(180px, 32vw, 300px);
    aspect-ratio: 1;
  }

  .hero-mark img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-copy {
    text-align: center;
  }

  .hero-title {
    font-size: var(--text-display);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.045em;
    margin: 0;
    color: var(--ink);
  }

  .hero-tag {
    margin-top: 1.1rem;
    font-size: clamp(1.0625rem, 1.4vw + 0.65rem, 1.4rem);
    font-weight: 700;
    color: var(--ink);
    max-width: 22ch;
    text-wrap: balance;
    margin-inline: auto;
  }

  .section {
    padding-block: clamp(2.25rem, 5vw, 3.5rem);
  }

  .status-line {
    margin-top: 0.4rem;
    font-size: 1.0625rem;
    color: var(--text);
    max-width: var(--max-prose);
    font-weight: 500;
  }

  .link-list {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 600;
  }

  @media (min-width: 720px) {
    .hero-grid {
      grid-template-columns: minmax(220px, 1fr) 2fr;
      justify-items: start;
    }

    .hero-mark {
      justify-self: start;
    }

    .hero-copy {
      text-align: left;
    }

    .hero-tag {
      margin-inline: 0;
    }
  }
</style>
